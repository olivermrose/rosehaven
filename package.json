{
	"name": "rosehaven",
	"type": "module",
	"private": true,
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"sync": "svelte-kit sync",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write src/**/*",
		"lint": "prettier --check src/**/* && eslint --fix",
		"docker:up": "docker compose up -d",
		"docker:down": "docker compose down",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"@takumi-rs/image-response": "beta",
		"@takumi-rs/wasm": "beta",
		"@threlte/core": "^8.5.5",
		"@tiptap/core": "^3.22.0",
		"@tiptap/extension-link": "^3.22.0",
		"@tiptap/extension-placeholder": "^3.22.0",
		"@tiptap/extension-text-align": "^3.22.0",
		"@tiptap/pm": "^3.22.0",
		"@tiptap/starter-kit": "^3.22.0",
		"chroma-js": "^3.2.0",
		"dayjs": "^1.11.20",
		"drizzle-orm": "1.0.0-beta.20",
		"lenis": "^1.3.21",
		"mode-watcher": "^1.1.0",
		"motion-sv": "^0.1.10",
		"pg": "^8.20.0",
		"runed": "^0.37.1",
		"three": "^0.183.2",
		"turndown": "^7.2.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^8.0.0",
		"@cloudflare/workers-types": "^4.20260401.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/chroma-js": "^3.1.2",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/three": "^0.183.1",
		"@types/turndown": "^5.0.6",
		"drizzle-kit": "1.0.0-beta.20",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.16.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"vite": "8.0.3",
		"wrangler": "^4.79.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"unrs-resolver"
		]
	}
}
